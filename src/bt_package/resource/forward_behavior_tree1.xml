<?xml version="1.0" encoding="UTF-8"?>
<root BTCPP_format="4" main_tree_to_execute="MainTree">
    
    <!-- 工业级三点巡航行为树 -->
    <!-- 功能：失败重试、点位停留、障碍物等待、导航取消、日志反馈、Groot监控 -->
    
    <!-- Groot Monitor 配置：连接 Groot 监控模块 -->
    <GrootMonitor>
        <!-- 行为树状态监控话题 -->
        <Publisher topic="/bt_monitor" type="behaviortree_msgs/BehaviorTreeLog" rate="10"/>
        <!-- 日志监控话题 -->
        <Publisher topic="/bt_log" type="std_msgs/String" rate="10"/>
        <!-- 服务器端口（用于 Groot 实时连接） -->
        <Server port="1666"/>
    </GrootMonitor>
    
    
    <!-- Blackboard 全局参数配置 -->
    <Blackboard>
        <Entry ID="max_retry" type="int" value="3"/>
        <Entry ID="stay_duration" type="double" value="5.0"/>
        <Entry ID="obstacle_wait_time" type="double" value="5.0"/>
        <Entry ID="current_waypoint_idx" type="int" value="0"/>
        <Entry ID="total_waypoints" type="int" value="3"/>
        <Entry ID="nav_result" type="int" value="0"/>
        <Entry ID="cancel_requested" type="bool" value="false"/>
        
        <!-- 三个巡航点位 -->
        <Entry ID="waypoint_1" type="geometry_msgs::msg::PoseStamped">
            {header: {frame_id: "map", stamp: {sec: 0, nanosec: 0}}, 
             pose: {position: {x: 1.0, y: 1.0, z: 0.0}, 
                    orientation: {x: 0.0, y: 0.0, z: 0.0, w: 1.0}}}
        </Entry>
        <Entry ID="waypoint_2" type="geometry_msgs::msg::PoseStamped">
            {header: {frame_id: "map", stamp: {sec: 0, nanosec: 0}}, 
             pose: {position: {x: 3.0, y: 1.0, z: 0.0}, 
                    orientation: {x: 0.0, y: 0.0, z: 0.0, w: 1.0}}}
        </Entry>
        <Entry ID="waypoint_3" type="geometry_msgs::msg::PoseStamped">
            {header: {frame_id: "map", stamp: {sec: 0, nanosec: 0}}, 
             pose: {position: {x: 3.0, y: 3.0, z: 0.0}, 
                    orientation: {x: 0.0, y: 0.0, z: 0.0, w: 1.0}}}
        </Entry>
    </Blackboard>

    <!-- 主行为树 -->
    <BehaviorTree ID="MainTree">
        <Sequence name="IndustrialPatrolSequence">
            
            <!-- 初始化阶段 -->
            <Sequence name="InitializationPhase">
                <Action ID="LogInfo" message="启动三点巡航任务"/>
                <Action ID="LogInfo" message="参数配置: 最大重试=3, 停留时间=5s, 障碍物等待=5s"/>
                
                <Action ID="Wait" wait_duration="2.0"/>
                
                <Action ID="LogInfo" message="初始化完成，开始巡航"/>
            </Sequence>

            <!-- 巡航主循环 -->
            <Sequence name="PatrolLoop">
                
                <!-- 路点 1 -->
                <Sequence name="Waypoint1Sequence">
                    <Action ID="LogInfo" message="========== 前往路点 1/3 [x:1.0, y:1.0] =========="/>
                    
                    <RetryUntilSuccessful num_attempts="3" name="NavigateToWaypoint1Retry">
                        <Sequence name="NavSequence1">
                            <Action ID="NavigateToPose" goal="{waypoint_1}"/>
                        </Sequence>
                    </RetryUntilSuccessful>
                    
                    <Action ID="LogInfo" message="路点 1 到达成功"/>
                    
                    <Fallback name="ObstacleCheckFallback1">
                        <Sequence name="ObstacleDetectedSequence1">
                            <Condition ID="IsObstacleDetected" detection_range="0.5"/>
                            <Action ID="LogWarn" message="路点1检测到障碍物，等待5秒"/>
                            <Action ID="Wait" wait_duration="5.0"/>
                            <Action ID="LogInfo" message="障碍物等待完成，继续执行"/>
                        </Sequence>
                        <Action ID="LogInfo" message="路点1无障碍物，继续执行"/>
                    </Fallback>
                    
                    <Action ID="LogInfo" message=" 路点1停留 5 秒"/>
                    <Action ID="Wait" wait_duration="5.0"/>
                    <Action ID="LogInfo" message=" 路点1停留完成"/>
                </Sequence>

                <!-- 路点 2 -->
                <Sequence name="Waypoint2Sequence">
                    <Action ID="LogInfo" message=" ========== 前往路点 2/3 [x:3.0, y:1.0] =========="/>
                    
                    <RetryUntilSuccessful num_attempts="3" name="NavigateToWaypoint2Retry">
                        <Sequence name="NavSequence2">
                            <Action ID="NavigateToPose" goal="{waypoint_2}"/>
                        </Sequence>
                    </RetryUntilSuccessful>
                    
                    <Action ID="LogInfo" message=" 路点 2 到达成功"/>
                    
                    <Fallback name="ObstacleCheckFallback2">
                        <Sequence name="ObstacleDetectedSequence2">
                            <Condition ID="IsObstacleDetected" detection_range="0.5"/>
                            <Action ID="LogWarn" message=" 路点2检测到障碍物，等待5秒"/>
                            <Action ID="Wait" wait_duration="5.0"/>
                            <Action ID="LogInfo" message=" 障碍物等待完成，继续执行"/>
                        </Sequence>
                        <Action ID="LogInfo" message="路点2无障碍物，继续执行"/>
                    </Fallback>
                    
                    <Action ID="LogInfo" message=" 路点2停留 5 秒"/>
                    <Action ID="Wait" wait_duration="5.0"/>
                    <Action ID="LogInfo" message=" 路点2停留完成"/>
                </Sequence>

                <!-- 路点 3 -->
                <Sequence name="Waypoint3Sequence">
                    <Action ID="LogInfo" message=" ========== 前往路点 3/3 [x:3.0, y:3.0] =========="/>
                    
                    <RetryUntilSuccessful num_attempts="3" name="NavigateToWaypoint3Retry">
                        <Sequence name="NavSequence3">
                            <Action ID="NavigateToPose" goal="{waypoint_3}"/>
                        </Sequence>
                    </RetryUntilSuccessful>
                    
                    <Action ID="LogInfo" message=" 路点 3 到达成功"/>
                    
                    <Fallback name="ObstacleCheckFallback3">
                        <Sequence name="ObstacleDetectedSequence3">
                            <Condition ID="IsObstacleDetected" detection_range="0.5"/>
                            <Action ID="LogWarn" message=" 路点3检测到障碍物，等待5秒"/>
                            <Action ID="Wait" wait_duration="5.0"/>
                            <Action ID="LogInfo" message="障碍物等待完成，继续执行"/>
                        </Sequence>
                        <Action ID="LogInfo" message=" 路点3无障碍物，继续执行"/>
                    </Fallback>
                    
                    <Action ID="LogInfo" message=" 路点3停留 5 秒"/>
                    <Action ID="Wait" wait_duration="5.0"/>
                    <Action ID="LogInfo" message=" 路点3停留完成"/>
                </Sequence>

            </Sequence>

            <!-- 任务完成 -->
            <Sequence name="TaskCompletion">
                <Action ID="LogInfo" message=" ========== 所有路点巡航完成！ =========="/>
                <Action ID="LogInfo" message=" 任务状态: SUCCESS"/>
            </Sequence>

        </Sequence>
    </BehaviorTree>

    <!-- TreeNodesModel 节点模型定义 -->
    <TreeNodesModel>
        
        <!-- 标准 Nav2 动作节点 -->
        <Action ID="NavigateToPose">
            <input_port name="goal" type="geometry_msgs::msg::PoseStamped">目标位姿</input_port>
        </Action>
        
        <Action ID="ComputePathToPose">
            <input_port name="goal" type="geometry_msgs::msg::PoseStamped">目标位姿</input_port>
            <output_port name="path" type="nav_msgs::msg::Path">规划路径</output_port>
        </Action>
        
        <Action ID="Wait">
            <input_port name="wait_duration" type="double">等待时间(秒)</input_port>
        </Action>
        
        <Action ID="ClearEntireCostmap">
            <input_port name="service_name" type="std::string">服务名称</input_port>
        </Action>
        
        <!-- 条件节点 -->
        <Condition ID="IsObstacleDetected">
            <input_port name="detection_range" type="double">检测距离(米)</input_port>
        </Condition>
        
        <Condition ID="IsCancelRequested"/>
        
        <!-- 自定义日志节点 -->
        <Action ID="LogInfo">
            <input_port name="message" type="std::string">INFO级别日志消息</input_port>
        </Action>
        
        <Action ID="LogWarn">
            <input_port name="message" type="std::string">WARN级别日志消息</input_port>
        </Action>
        
        <Action ID="LogError">
            <input_port name="message" type="std::string">ERROR级别日志消息</input_port>
        </Action>
        
    </TreeNodesModel>
</root>